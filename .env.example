# Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Use the anon / public key (JWT eyJ... or publishable sb_publishable_...)
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY

# Optional: Postgres direct URL is for migrations/CLI only — never put the DB password in Vite env.

